{
  "name": "project-s3",
  "version": "1.0.0",
  "description": "Gemini Flash API & Web UI - Full stack application with Express backend and Next.js frontend",
  "scripts": {
    "dev": "concurrently -n backend,next -c blue.bgWhite,green.bgWhite \"npm run dev:backend\" \"npm run dev:next\"",
    "dev:backend": "sh -c 'cd backend && npm run dev'",
    "dev:next": "next dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "next build",
    "start": "concurrently -n backend,next \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "sh -c 'cd backend && npm start'",
    "start:frontend": "next start",
    "lint": "eslint",
    "clean": "rm -rf backend/node_modules node_modules backend/.env .env.local .next",
    "install:all": "npm install && (cd backend && npm install)",
    "test": "bun test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:backend": "sh -c 'cd backend && npm test'"
  },
  "keywords": [
    "gemini",
    "ai",
    "express",
    "api",
    "next.js",
    "react",
    "fullstack"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@ai-sdk/react": "^3.0.179",
    "ai": "^6.0.177",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^8.2.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
